{
  "openapi": "3.0.3",
  "info": { "title": "OWBastion Platform API", "version": "1.0.0" },
  "servers": [{ "url": "https://api.owbastion.com" }],
  "paths": {
    "/health": { "get": { "operationId": "getHealth", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/auth/qq/login-attempt": { "post": { "operationId": "createQqLoginAttempt", "responses": { "201": { "$ref": "#/components/responses/Json" } } } },
    "/v1/auth/qq/login-attempt/{attemptId}": { "get": { "operationId": "getQqLoginAttempt", "parameters": [{ "$ref": "#/components/parameters/attemptId" }], "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/qq/auth/verify": { "post": { "operationId": "verifyQqLogin", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/me": { "get": { "operationId": "getCurrentPlayer", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/me/titles": { "get": { "operationId": "listCurrentPlayerTitles", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/me/submissions/{submissionId}": { "get": { "operationId": "getPlayerSubmission", "parameters": [{ "$ref": "#/components/parameters/submissionId" }], "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/me/submissions/{submissionId}/evidence": { "get": { "operationId": "getPlayerEvidence", "parameters": [{ "$ref": "#/components/parameters/submissionId" }], "responses": { "200": { "description": "Private evidence image" } } } },
    "/v1/auth/logout": { "post": { "operationId": "logout", "responses": { "204": { "description": "Logged out" } } } },
    "/v1/public/achievements": { "get": { "operationId": "listPublicAchievements", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
