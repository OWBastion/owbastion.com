    "/v1/public/binding-claims/{claimId}": { "get": { "operationId": "getBindingClaimStatus", "parameters": [{ "$ref": "#/components/parameters/claimId" }, { "$ref": "#/components/parameters/claimToken" }], "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/challenges": { "get": { "operationId": "listChallenges", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/titles": { "get": { "operationId": "listTitles", "parameters": [{ "$ref": "#/components/parameters/mapIdQuery" }], "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/maps": { "get": { "operationId": "listMaps", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/events": { "get": { "operationId": "listRandomEvents", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/events/{eventId}": { "get": { "operationId": "getRandomEvent", "parameters": [{ "$ref": "#/components/parameters/eventId" }], "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/player/uploads/session": { "post": { "operationId": "createPlayerUploadSession", "responses": { "201": { "$ref": "#/components/responses/Json" } } } },
    "/v1/uploads/{uploadId}": { "put": { "operationId": "uploadEvidence", "parameters": [{ "$ref": "#/components/parameters/uploadId" }], "responses": { "204": { "description": "Uploaded" } } } },
    "/v1/player/uploads/{uploadId}/complete": { "post": { "operationId": "completePlayerUpload", "parameters": [{ "$ref": "#/components/parameters/uploadId" }], "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/admin/qq/groups/{groupOpenId}": { "put": { "operationId": "updateQqGroupAccess", "parameters": [{ "$ref": "#/components/parameters/groupOpenId" }], "responses": { "204": { "description": "Updated" } } } },
    "/v1/admin/qq/groups": { "get": { "operationId": "listQqGroupAccess", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/admin/player-accounts": { "get": { "operationId": "listAdminPlayers", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/admin/player-accounts/{playerAccountId}": { "get": { "operationId": "getAdminPlayer", "parameters": [{ "$ref": "#/components/parameters/playerAccountId" }], "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/admin/player-accounts/{playerAccountId}/status": { "put": { "operationId": "updateAdminPlayerStatus", "parameters": [{ "$ref": "#/components/parameters/playerAccountId" }], "responses": { "204": { "description": "Updated" } } } },
    "/v1/admin/achievements": { "get": { "operationId": "listAdminAchievements", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/admin/maps": { "get": { "operationId": "listAdminMaps", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/admin/events": { "get": { "operationId": "listAdminRandomEvents", "responses": { "200": { "$ref": "#/components/responses/Json" } } }, "post": { "operationId": "createAdminRandomEvent", "responses": { "201": { "$ref": "#/components/responses/Json" } } } },
    "/v1/admin/events/{eventId}": { "put": { "operationId": "updateAdminRandomEvent", "parameters": [{ "$ref": "#/components/parameters/eventId" }], "responses": { "200": { "$ref": "#/components/responses/Json" } } }, "delete": { "operationId": "archiveAdminRandomEvent", "parameters": [{ "$ref": "#/components/parameters/eventId" }], "responses": { "204": { "description": "Archived" } } } },
    "/v1/admin/events/imports/preview": { "post": { "operationId": "previewRandomEventImport", "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/admin/events/imports": { "post": { "operationId": "importRandomEvents", "responses": { "201": { "$ref": "#/components/responses/Json" } } } },
    "/v1/admin/maps/{mapId}/metadata": { "put": { "operationId": "updateAdminMapMetadata", "parameters": [{ "$ref": "#/components/parameters/mapId" }], "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
    "/v1/admin/titles/{titleKey}": { "put": { "operationId": "updateAdminTitle", "parameters": [{ "$ref": "#/components/parameters/titleKey" }], "responses": { "204": { "description": "Updated" } } } },
    "/v1/admin/achievements/{challengeId}": { "put": { "operationId": "updateAdminAchievement", "parameters": [{ "$ref": "#/components/parameters/challengeId" }], "responses": { "200": { "$ref": "#/components/responses/Json" } } } },
