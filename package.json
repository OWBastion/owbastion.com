{
  "name": "@owbastion/codes",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev:portal": "pnpm --filter @owbastion/portal dev",
    "dev:api": "pnpm exec wrangler dev --config wrangler.toml",
    "dev:api:local": "pnpm exec wrangler dev --config wrangler.local.toml",
    "dev:portal:local": "HOST=0.0.0.0 PORT=3000 NUXT_PUBLIC_API_BASE_URL=http://localhost:8787 NUXT_PUBLIC_LOCAL_DEV_AUTH=true pnpm --filter @owbastion/portal dev",
    "dev:local": "bash tools/dev-local.sh",
    "db:seed:local": "bash tools/seed-local.sh",
    "db:generate-title-migration": "node --experimental-strip-types tools/generate-title-catalog-migration.ts",
    "build:portal": "pnpm --filter @owbastion/portal build",
    "build:api": "pnpm --filter @owbastion/api build",
    "build": "pnpm --recursive --if-present run build",
    "pretest": "pnpm --filter @owbastion/portal exec nuxi prepare",
    "typecheck:portal": "pnpm --filter @owbastion/portal typecheck",
    "typecheck:api": "pnpm --filter @owbastion/api typecheck",
    "test": "vitest run && pnpm run test:portal-ui --run",
    "test:portal-ui": "pnpm --filter @owbastion/portal run test:ui",
    "test:api": "pnpm exec vitest run apps/api",
    "typecheck": "pnpm --recursive --if-present run typecheck",
    "check": "pnpm run test && pnpm run typecheck && pnpm run build"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "@vue/test-utils": "^2.4.6",
    "@cloudflare/workers-types": "^4.20250705.0",
    "drizzle-kit": "^0.31.4",
    "happy-dom": "^20.10.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.20.5"
  }
}
