{
  "name": "@owbastion/codes",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev:portal": "pnpm --filter @owbastion/portal dev",
    "dev:api": "pnpm exec wrangler dev --config wrangler.toml",
    "build:portal": "pnpm --filter @owbastion/portal build",
    "build:api": "pnpm --filter @owbastion/api build",
    "build": "pnpm --recursive --if-present run build",
    "typecheck:portal": "pnpm --filter @owbastion/portal typecheck",
    "typecheck:api": "pnpm --filter @owbastion/api typecheck",
    "test": "vitest run",
    "test:api": "pnpm exec vitest run apps/api",
    "typecheck": "pnpm --recursive --if-present run typecheck",
    "check": "pnpm run test && pnpm run typecheck && pnpm run build"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.20.5"
  }
}
